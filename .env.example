# OdontoSync - Variáveis de Ambiente

# Flask
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Google Gemini AI (opcional - para sugestões inteligentes)
GEMINI_API_KEY=your-gemini-api-key-here

# API de Clima (futuro - preparado para integração)
WEATHER_API_KEY=your-openweathermap-api-key-here
# Obtenha sua chave em: https://openweathermap.org/api

# Configurações opcionais
DEFAULT_CITY=São Paulo
USE_WEATHER_API=False  # Ative quando tiver a API key configurada
USE_AI_SUGGESTIONS=True  # Requer GEMINI_API_KEY
